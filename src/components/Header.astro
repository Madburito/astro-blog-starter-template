---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		    <a href="#top" class="brand-link">
				<img src="/images/logo.jpeg" alt="Martens Driving School" class="brand-logo" />
				<span class="brand-text">{SITE_TITLE}</span>
			</a>
		    <button class="menu-toggle" aria-expanded="false" aria-controls="primary-nav">
				<span class="sr-only">Toggle menu</span>
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
					<path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</button>
		    <div id="primary-nav" class="internal-links">
			    <HeaderLink href="#services">Services</HeaderLink>
			    <HeaderLink href="#instructor">Instructor</HeaderLink>
			    <HeaderLink href="#contact">Book</HeaderLink>
		    </div>
		<div class="social-links">
			<a href="https://www.instagram.com/martensdrivingschool/" target="_blank">
			<span class="sr-only">Follow Martens Driving School</span>
			  <svg
   				 xmlns="http://www.w3.org/2000/svg"
    			 width="24"
				 height="24"
			     viewBox="0 0 24 24"
				 fill="none"
				 stroke="currentColor"
				 stroke-width="2"
				 stroke-linecap="round"
				 stroke-linejoin="round"
  				>
				<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
				<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
				<line x1="17.5" y1="6.5" x2="17.5" y2="6.5"></line>
			  </svg>
				
		</a
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(234,241,246,0.7));
		backdrop-filter: blur(4px);
		box-shadow: 0 10px 30px rgba(16,39,56,0.07);
		position: sticky;
		top: 0;
		z-index: 40;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		padding: 0.6rem 0;
	}
	h2 {
		margin: 0;
		font-size: 1.6rem;
		font-weight: 800;
		color: var(--primary);
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	.brand-link {
		display: flex;
		align-items: center;
		text-decoration: none;
		gap: 0.75rem;
	}
	.brand-logo {
		height: 50px;
		width: 50px;
		border-radius: 50%;
		display: block;
		object-fit: cover;
	}
	.brand-text {
		font-size: 1.6rem;
		font-weight: 800;
		color: rgb(var(--black));
	}
	.internal-links {
		display: flex;
		gap: 0.75rem;
		align-items: center;
	}
	nav a {
		padding: 0.5rem 0.5rem;
		color: rgb(var(--black));
		border-bottom: 3px solid transparent;
		text-decoration: none;
	}
	nav a:hover {
		border-bottom-color: rgba(var(--black), 0.06);
	}

	/* mobile menu toggle */
	.menu-toggle {
		display: none;
		background: transparent;
		border: none;
		padding: 0.25rem;
		margin-left: 0.5rem;
		color: rgb(var(--black));
		cursor: pointer;
	}
	.menu-toggle svg { display: block; }

	/* when screen is small, hide the inline links and show a stacked menu */
	@media (max-width: 720px) {
		.menu-toggle { display: inline-flex; align-items: center; }
		.internal-links { display: none; }
		.internal-links.open {
			display: flex;
			flex-direction: column;
			gap: 0.25rem;
			position: absolute;
			top: 100%;
			right: 1rem;
			background: var(--page-bg);
			padding: 0.6rem;
			border-radius: 8px;
			box-shadow: 0 8px 24px rgba(11,27,40,0.12);
			min-width: 160px;
		}
		.internal-links a {
			display: block;
			padding: 0.5rem 0.75rem;
		}
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		nav {
			padding: 0.5rem 0;
		}
	}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
	const btn = document.querySelector('.menu-toggle');
	if (!btn) return;
	const nav = btn.closest('nav');
	const menu = nav && nav.querySelector('.internal-links');
	btn.addEventListener('click', () => {
		const open = menu.classList.toggle('open');
		btn.setAttribute('aria-expanded', open ? 'true' : 'false');
	});
});
</script>
