---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const HOME_TITLE = 'Driving School in Steinbach, MB | Martens Driving School';
const HOME_DESCRIPTION = 'MPI certified one-on-one driving lessons, road test prep, and road test car rental in Steinbach and surrounding communities.';
const HOME_KEYWORDS = 'driving school steinbach, driving instructor steinbach, road test prep steinbach, driving lessons steinbach manitoba';
const siteOrigin = Astro.site ? Astro.site.toString().replace(/\/$/, '') : Astro.url.origin;

const HOME_STRUCTURED_DATA = [
	{
		'@context': 'https://schema.org',
		'@type': 'DrivingSchool',
		name: 'Martens Driving School',
		description: HOME_DESCRIPTION,
		url: `${siteOrigin}/`,
		telephone: '(204) 371-7417',
		email: 'Martensdrivingschool@gmail.com',
		areaServed: ['Steinbach', 'Southeast Manitoba'],
		image: `${siteOrigin}/images/logo.jpeg`,
		address: {
			'@type': 'PostalAddress',
			addressLocality: 'Steinbach',
			addressRegion: 'MB',
			addressCountry: 'CA'
		},
		serviceType: ['One-on-One Driving Lessons', 'Road Test Preparation', 'Road Test Car Rental']
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: [
			{
				'@type': 'Question',
				name: 'How long is each lesson?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'Most lessons are booked in hourly sessions, with options based on your needs and goals.'
				}
			},
			{
				'@type': 'Question',
				name: 'Do you provide a vehicle for road tests?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'Yes. Road test car rental is available.'
				}
			},
			{
				'@type': 'Question',
				name: 'What areas do you serve?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'Steinbach and surrounding communities.'
				}
			}
		]
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={HOME_TITLE} description={HOME_DESCRIPTION} keywords={HOME_KEYWORDS} structuredData={HOME_STRUCTURED_DATA} />
	</head>
	<body>
		<Header />
		<main id="top" class="prose page-content">
			<section class="hero">
				<div class="hero-inner">
					<h1>Welcome to Martens Driving School</h1>
					<p>
						Learning to drive should feel comfortable and supportive. At Martens Driving School, our goal is to help you become a safe and confident driver, not just someone who can pass a road test.
					</p>
					<p>
						We offer one on one driving lessons in a calm and patient environment. Every lesson is adapted to your experience level so you can learn at your own pace and feel confident behind the wheel.
					</p>
					<p>
						Martens Driving School proudly serves students in Steinbach and surrounding communities.
					</p>
					<div class="hero-cta">
						<a class="btn btn-navy" href="#contact">Book a Lesson</a>
					</div>
				</div>
			</section>

			<section id="services" class="services">
				<h2>Driving Lessons and Services</h2>
				<ul class="services-list">
					<li>🚘 One-on-One Driving Lessons  $80/hour</li>
					<li>🚗 Road Test Car Rental  $100</li>
				</ul>
				<p>
					Whether you are just starting to learn or preparing for your road test, lessons focus on real world driving skills that will help you feel comfortable on the road.
				</p>
			</section>

			<section id="instructor" class="instructor">
				<h2>Meet Your Instructor</h2>
				<div class="instructor-grid">
					<figure class="instructor-figure">
						<img src="/images/instructor.jpg" alt="Noemi Martens, instructor at Martens Driving School" />
					</figure>
					<p>
						Hi, I’m Noemi Martens, owner and instructor at Martens Driving School.
						I am an MPI certified driving instructor and a certified Manitoba teacher with over 25 years of classroom teaching experience. Teaching has always been something I truly enjoy, and I love helping students gain confidence both in the classroom and behind the wheel.			</p>
				</div>
			</section>


			<section id="contact" class="contact">
				<h2>Book a Lesson</h2>
				<p>
					If you would like to schedule a lesson or have any questions, feel free to reach out.
				</p>
				<p>Email: <a href="mailto:Martensdrivingschool@gmail.com">Martensdrivingschool@gmail.com</a></p>
				<p>SMS/Text: <a href="sms:+12043717417">(204) 371-7417</a></p>
				<!-- Contact form for lesson bookings -->
				<form class="contact-form" action="https://formsubmit.co/Martensdrivingschool@gmail.com" method="POST">
					<input type="hidden" name="_subject" value="New lesson booking from Martens Driving School site" />
					<input type="hidden" name="_captcha" value="false" />
					<input id="cf-next" type="hidden" name="_next" value="" />
					<input id="cf-winnipeg" type="hidden" name="submission_date_winnipeg" value="" />
					
					<label for="cf-name">Name <span class="required">*</span></label>
					<input id="cf-name" name="name" type="text" placeholder="Your name" required />
					
					<label for="cf-email">Email <span class="required">*</span></label>
					<input id="cf-email" name="email" type="email" placeholder="your@email.com" />
					<small class="form-hint">Email or phone required</small>
					
					<label for="cf-phone">Phone Number <span class="required">*</span></label>
					<input id="cf-phone" name="phone" type="tel" placeholder="(123) 456-7890" />
					
					<label>Preferred Days of the Week (select all that apply)</label>
					<div class="checkbox-group">
						<label><input type="checkbox" name="preferred_days[]" value="monday"> Monday</label>
						<label><input type="checkbox" name="preferred_days[]" value="tuesday"> Tuesday</label>
						<label><input type="checkbox" name="preferred_days[]" value="wednesday"> Wednesday</label>
						<label><input type="checkbox" name="preferred_days[]" value="thursday"> Thursday</label>
						<label><input type="checkbox" name="preferred_days[]" value="friday"> Friday</label>
						<label><input type="checkbox" name="preferred_days[]" value="saturday"> Saturday</label>
						<label><input type="checkbox" name="preferred_days[]" value="sunday"> Sunday</label>
					</div>
					
					<label for="cf-time">Preferred Time <span class="required">*</span></label>
					<select id="cf-time" name="preferred_time" required>
						<option value="">Select a time</option>
						<option value="morning">Morning (8am - 12pm)</option>
						<option value="afternoon">Afternoon (12pm - 5pm)</option>
						<option value="evening">Evening (5pm - 9pm)</option>
					</select>
					<label for="cf-message">Message</label>
					<textarea id="cf-message" name="message" rows="5" placeholder="Tell us more about your driving goals or any questions..."></textarea>
					
					<button type="submit" class="btn btn-primary">Book Your Lesson</button>
					<p class="form-status" aria-live="polite"></p>
				</form>
			</section>

			<section id="service-area" class="service-area">
				<h2>Service Area</h2>
				<p>We proudly serve Steinbach and surrounding communities.</p>
				<div class="map-container">
					<iframe
						width="600"
						height="450"
						style="border:0;"
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						src="https://www.google.com/maps?q=Martens+Driving+School+Steinbach+MB&output=embed"
						allowfullscreen="" aria-hidden="false" tabindex="0">
					</iframe>
				</div>
			</section>

			<section class="faq" id="faq">
				<h2>Frequently Asked Questions</h2>
				<details>
					<summary>How long is each lesson?</summary>
					<p>Most lessons are booked in hourly sessions, with options based on your needs and goals.</p>
				</details>
				<details>
					<summary>Do you provide a vehicle for road tests?</summary>
					<p>Yes. Road test car rental is available.</p>
				</details>
				<details>
					<summary>What areas do you serve?</summary>
					<p>Steinbach and surrounding communities.</p>
				</details>
			</section>

			<a class="sticky-mobile-cta" href="#contact">Book a Lesson</a>

			<script>
				// Check if form was just submitted successfully
				const params = new URLSearchParams(window.location.search);
				if (params.has('sent') && params.get('sent') === '1') {
					const statusEl = document.querySelector('.contact-form .form-status');
					if (statusEl) {
						statusEl.textContent = 'Message sent. We will get back to you soon.';
						statusEl.classList.add('is-success');
						// Remove the query param from URL without reloading
						window.history.replaceState({}, document.title, window.location.pathname + '#contact');
					}
				}

				const contactForm = document.querySelector('.contact-form');
				if (contactForm) {
					const emailField = document.getElementById('cf-email');
					const phoneField = document.getElementById('cf-phone');
					const winnipegField = document.getElementById('cf-winnipeg');
					const nextField = document.getElementById('cf-next');
					const submitButton = contactForm.querySelector('button[type="submit"]');
					const statusEl = contactForm.querySelector('.form-status');

					if (nextField) {
						nextField.value = `${window.location.origin}${window.location.pathname}?sent=1#contact`;
					}

					contactForm.addEventListener('submit', function(e) {
						const email = document.getElementById('cf-email').value.trim();
						const phone = document.getElementById('cf-phone').value.trim();

						if (statusEl) {
							statusEl.textContent = '';
							statusEl.classList.remove('is-error', 'is-success');
						}

						if (!email && !phone) {
							e.preventDefault();
							if (statusEl) {
								statusEl.textContent = 'Please provide either an email address or phone number.';
								statusEl.classList.add('is-error');
							}
							emailField?.focus();
							return;
						}
						const winnipegDate = new Date().toLocaleString('en-CA', { timeZone: 'America/Winnipeg', hour12: false });
						if (winnipegField) {
							winnipegField.value = winnipegDate;
						}
						if (typeof window.gtag === 'function') {
							window.gtag('event', 'generate_lead', { method: 'form_submit' });
						}

						if (submitButton) {
							submitButton.disabled = true;
							submitButton.textContent = 'Sending...';
						}
						// Allow the form to submit naturally to FormSubmit
					});
				}

				document.querySelectorAll('a[href^="mailto:"]').forEach((el) => {
					el.addEventListener('click', () => {
						if (typeof window.gtag === 'function') {
							window.gtag('event', 'contact', { method: 'email_click' });
						}
					});
				});

				document.querySelectorAll('a[href^="sms:"]').forEach((el) => {
					el.addEventListener('click', () => {
						if (typeof window.gtag === 'function') {
							window.gtag('event', 'contact', { method: 'sms_click' });
						}
					});
				});

				const mapFrame = document.querySelector('.service-area iframe');
				if (mapFrame) {
					mapFrame.addEventListener('click', () => {
						if (typeof window.gtag === 'function') {
							window.gtag('event', 'view_map', { area: 'steinbach' });
						}
					});
				}
			</script>
		</main>
		<Footer />
	</body>
</html>